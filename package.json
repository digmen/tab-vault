{
  "name": "tab-vault",
  "version": "1.0.0",
  "description": "Park tabs to free memory, restore them anytime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "assets": "node render_assets.mjs && python finalize_assets.py"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.2",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.7.2"
  }
}
